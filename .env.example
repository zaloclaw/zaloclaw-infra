# OpenClaw + LiteLLM example environment

OPENCLAW_CONFIG_DIR=$HOME/.openclaw
OPENCLAW_WORKSPACE_DIR=$HOME/.openclaw/workspace
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-long-random-token
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:2026.3.28
OPENCLAW_EXTRA_MOUNTS=
OPENCLAW_HOME_VOLUME=openclaw_home
OPENCLAW_DOCKER_APT_PACKAGES=
OPENCLAW_EXTENSIONS=
OPENCLAW_SANDBOX=
OPENCLAW_DOCKER_SOCKET=/var/run/docker.sock
DOCKER_GID=
OPENCLAW_INSTALL_DOCKER_CLI=
OPENCLAW_INSTALL_BROWSER=1
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=
OPENCLAW_TZ=
OPENCLAW_REMOTE_CDP_URL=http://192.168.65.254:9222
# OpenAI
OPENAI_API_KEY=
# Google
GOOGLE_API_KEY=
# Anthropic
ANTHROPIC_API_KEY=
# LiteLLM
LITELLM_MASTER_KEY=
# OpenRouter
OPENROUTER_API_KEY=