{
  "browser": {
    "enabled": true,
    "remoteCdpTimeoutMs": 1500,
    "remoteCdpHandshakeTimeoutMs": 3000,
    "color": "#FF4500",
    "executablePath": "/home/node/.cache/ms-playwright/chromium-1208/chrome-linux/chrome",
    "headless": false,
    "noSandbox": false,
    "attachOnly": false,
    "defaultProfile": "remote",
    "ssrfPolicy": {
      "dangerouslyAllowPrivateNetwork": true
    },
    "profiles": {
      "openclaw": {
        "cdpPort": 18800,
        "color": "#FF4500"
      },
      "work": {
        "cdpPort": 18801,
        "color": "#0066CC"
      },
      "user": {
        "driver": "existing-session",
        "attachOnly": true,
        "color": "#00AA00"
      },
      "remote": {
        "cdpUrl": "__OPENCLAW_REMOTE_CDP_URL__",
        "attachOnly": true,
        "color": "#00AA00"
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "litellm": {
        "baseUrl": "http://host.docker.internal:4000",
        "apiKey": "__LITELLM_MASTER_KEY__",
        "auth": "api-key",
        "api": "openai-completions",
        "models": [
          {
            "id": "openclaw-smart-router",
            "name": "Auto Router - Complexity",
            "reasoning": false,
            "input": [
              "text",
              "image"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 128000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "litellm/openclaw-smart-router"
      },
      "models": {
        "litellm/openclaw-smart-router": {
          "alias": "LiteLLM"
        }
      },
      "workspace": "/home/node/.openclaw/workspace",
      "compaction": {
        "mode": "safeguard"
      },
      "sandbox": {
        "mode": "off"
      }
    },
    "list": [
      {
        "id": "main",
        "model": "litellm/openclaw-smart-router",
        "skills": [
          "local-search",
          "1password",
          "apple-notes",
          "apple-reminders",
          "bear-notes",
          "blogwatcher",
          "blucli",
          "bluebubbles",
          "camsnap",
          "clawhub",
          "coding-agent",
          "discord",
          "eightctl",
          "gemini",
          "gh-issues",
          "gifgrep",
          "github",
          "gog",
          "goplaces",
          "healthcheck",
          "himalaya",
          "imsg",
          "model-usage",
          "nano-banana-pro",
          "nano-pdf",
          "node-connect",
          "notion",
          "obsidian",
          "openai-image-gen",
          "openai-whisper",
          "openai-whisper-api",
          "openhue",
          "oracle",
          "ordercli",
          "peekaboo",
          "sag",
          "session-logs",
          "sherpa-onnx-tts",
          "skill-creator",
          "slack",
          "songsee",
          "sonoscli",
          "spotify-player",
          "summarize",
          "things-mac",
          "tmux",
          "trello",
          "video-frames",
          "voice-call",
          "wacli",
          "weather",
          "xurl",
          "mcporter"
        ]
      }
    ]
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": [
        "http://127.0.0.1:__OPENCLAW_GATEWAY_PORT__",
        "http://localhost:3000"
      ],
      "dangerouslyAllowHostHeaderOriginFallback": true,
      "allowInsecureAuth": true,
      "dangerouslyDisableDeviceAuth": true
    },
    "auth": {
      "mode": "token"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "contacts.add",
        "calendar.add",
        "reminders.add",
        "sms.send"
      ]
    }
  },
  "skills": {
    "load": {
      "extraDirs": [
        "/home/node/.openclaw/workspace/skills"
      ],
      "watch": true
    },
    "install": {
      "nodeManager": "npm"
    },
    "entries": {
      "mcporter": {
        "enabled": true
      }
    }
  },
  "plugins": {
    "entries": {
      "telegram": {
        "enabled": true
      },
      "zalo": {
        "enabled": true
      }
    }
  },
  "tools": {
    "profile": "full",
    "alsoAllow": [
      "/usr/local/bin/gog",
      "/bin/ls",
      "/usr/bin/ls",
      "/bin/sh",
      "/bin/bash"
    ],
    "exec": {
      "security": "full",
      "ask": "off"
    }
  }
}
